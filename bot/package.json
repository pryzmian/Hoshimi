{
    "name": "hoshimi-test",
    "version": "1.0.0",
    "description": "A example bot to show how to use hoshimi",
    "main": "./src/index.ts",
    "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40",
    "keywords": [],
    "author": "",
    "license": "MIT",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "start": "tsx ./src/index.ts",
        "dev": "tsx ./src/index.ts --debug",
        "lint": "biome lint --write .",
        "format": "biome format --write ."
    },
    "dependencies": {
        "dotenv": "^17.2.3",
        "hoshimi": "link:..",
        "seyfert": "github:tiramisulabs/seyfert",
        "yunaforseyfert": "github:SagiriIkeda/yunaforseyfert"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.4",
        "@types/node": "^24.10.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@biomejs/biome",
            "esbuild"
        ]
    }
}
