{
    "name": "hoshimi-test",
    "version": "1.0.0",
    "description": "A example bot to show how to use hoshimi",
    "main": "./src/index.ts",
    "type": "module",
    "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937",
    "keywords": [],
    "author": "",
    "license": "MIT",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "start": "tsx ./src/index.ts",
        "dev": "tsx ./src/index.ts --debug",
        "lint": "biome lint --write .",
        "format": "biome format --write ."
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "hoshimi": "link:..",
        "meowdb": "^2.2.3",
        "redis": "^5.11.0",
        "seyfert": "github:tiramisulabs/seyfert",
        "yunaforseyfert": "github:SagiriIkeda/yunaforseyfert"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.2",
        "@types/node": "^25.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@biomejs/biome",
            "esbuild",
            "seyfert"
        ]
    }
