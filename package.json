{
    "name": "hoshimi",
    "version": "0.1.0",
    "description": "A lavalink@v4 client easy to use, up-to-date.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706",
    "files": [
        "dist"
    ],
    "lint-staged": {
        "*.{ts,json}": [
            "pnpm format"
        ]
    },
    "repository": {
        "url": "https://github.com/Ganyu-Studios/Hoshimi.git",
        "type": "git"
    },
    "scripts": {
        "build": "pnpm typecheck && tsup",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "prepare": "husky && pnpm build",
        "tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
        "tool:publish": "cd .npm && npm publish"
    },
    "keywords": [
        "discord",
        "lavalink",
        "lavalink-v4",
        "discord",
        "distube",
        "music-bot",
        "lavalink-player",
        "lavalink-client",
        "music"
    ],
    "author": "Ganyu Studios",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.2.4",
        "@types/node": "^24.5.2",
        "@types/ws": "^8.18.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.6",
        "tsup": "^8.5.0",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2"
    },
    "dependencies": {
        "ws": "^8.18.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
