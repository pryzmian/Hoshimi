{
	"name": "hoshimi",
	"version": "0.1.0",
	"description": "A lavalink@v4 client easy to use, up-to-date.",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac",
	"files": [
		"dist"
	],
	"lint-staged": {
		"*.{ts,json}": [
			"pnpm format"
		]
	},
	"repository": {
		"url": "https://github.com/Ganyu-Studios/Hoshimi.git",
		"type": "git"
	},
	"scripts": {
		"build": "pnpm typecheck && tsup",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"prepare": "husky && pnpm build",
		"tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
		"tool:publish": "cd .npm && npm publish"
	},
	"keywords": [
		"discord",
		"lavalink",
		"lavalink-v4",
		"discord",
		"distube",
		"music-bot",
		"lavalink-player",
		"lavalink-client",
		"music"
	],
	"author": "Ganyu Studios",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.0.5",
		"@types/node": "^24.0.4",
		"@types/ws": "^8.18.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"tsup": "^8.5.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"ws": "^8.18.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
