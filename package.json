{
	"name": "hoshimi",
	"version": "0.1.0",
	"description": "A lavalink@v4 client easy to use, up-to-date.",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
	"files": [
		"dist"
	],
	"lint-staged": {
		"*.{ts,json}": [
			"pnpm format"
		]
	},
	"repository": {
		"url": "https://github.com/Ganyu-Studios/Hoshimi.git",
		"type": "git"
	},
	"scripts": {
		"build": "pnpm typecheck && tsup",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"prepare": "husky && pnpm build",
		"tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
		"tool:publish": "cd .npm && npm publish"
	},
	"keywords": [
		"discord",
		"lavalink",
		"lavalink-v4",
		"discord",
		"distube",
		"music-bot",
		"lavalink-player",
		"lavalink-client",
		"music"
	],
	"author": "Ganyu Studios",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@types/node": "^24.0.13",
		"@types/ws": "^8.18.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"tsup": "^8.5.0",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"ws": "^8.18.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
