{
	"name": "hoshimi",
	"version": "0.1.0",
	"description": "A lavalink@v4 client easy to use, up-to-date.",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"packageManager": "pnpm@10.7.1+sha512.2d92c86b7928dc8284f53494fb4201f983da65f0fb4f0d40baafa5cf628fa31dae3e5968f12466f17df7e97310e30f343a648baea1b9b350685dafafffdf5808",
	"files": ["dist"],
	"lint-staged": {
		"*.{ts,json}": ["pnpm format"]
	},
	"repository": {
		"url": "https://github.com/Ganyu-Studios/Hoshimi.git",
		"type": "git"
	},
	"scripts": {
		"build": "tsup",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"prepare": "pnpm build && husky",
		"tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
		"tool:publish": "cd .npm && npm publish"
	},
	"keywords": [
		"discord",
		"lavalink",
		"lavalink-v4",
		"discord",
		"distube",
		"music-bot",
		"lavalink-player",
		"lavalink-client",
		"music"
	],
	"author": "Ganyu Studios",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.14.0",
		"@types/ws": "^8.18.1",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.0",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"ws": "^8.18.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild"]
	}
}
