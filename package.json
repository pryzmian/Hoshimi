{
    "name": "hoshimi",
    "version": "0.3.1",
    "description": "A lavalink@v4 client easy to use, up-to-date and all ears.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
    "files": [
        "dist"
    ],
    "lint-staged": {
        "*.{ts,json}": [
            "pnpm format"
        ]
    },
    "repository": {
        "url": "https://github.com/Ganyu-Studios/Hoshimi.git",
        "type": "git"
    },
    "scripts": {
        "build": "pnpm typecheck && tsup",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "prepare": "husky && pnpm build",
        "tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
        "tool:publish": "cd .npm && npm publish"
    },
    "keywords": [
        "discord",
        "lavalink",
        "lavalink-v4",
        "discord",
        "distube",
        "music-bot",
        "lavalink-player",
        "lavalink-client",
        "music"
    ],
    "author": "Ganyu Studios",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.3.8",
        "@types/node": "^24.10.1",
        "@types/ws": "^8.18.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "ws": "^8.18.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
