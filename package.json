{
    "name": "hoshimi",
    "version": "0.3.9",
    "description": "A lavalink@v4 client easy to use, up-to-date and all ears.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "lint-staged": {
        "*.{ts,json}": [
            "pnpm format"
        ]
    },
    "repository": {
        "url": "https://github.com/Ganyu-Studios/Hoshimi.git",
        "type": "git"
    },
    "scripts": {
        "build": "pnpm typecheck && tsup",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "prepare": "husky && pnpm build",
        "tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
        "tool:publish": "cd .npm && npm publish"
    },
    "keywords": [
        "discord",
        "lavalink",
        "lavalink-v4",
        "discord",
        "distube",
        "music-bot",
        "lavalink-player",
        "lavalink-client",
        "music"
    ],
    "author": "Ganyu Studios",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@changesets/cli": "^2.30.0",
        "@types/node": "^25.5.0",
        "@types/ws": "^8.18.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "ws": "^8.19.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
