{
    "name": "hoshimi",
    "version": "0.2.5",
    "description": "A lavalink@v4 client easy to use, up-to-date and all ears.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40",
    "files": [
        "dist"
    ],
    "lint-staged": {
        "*.{ts,json}": [
            "pnpm format"
        ]
    },
    "repository": {
        "url": "https://github.com/Ganyu-Studios/Hoshimi.git",
        "type": "git"
    },
    "scripts": {
        "build": "pnpm typecheck && tsup",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "prepare": "husky && pnpm build",
        "tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
        "tool:publish": "cd .npm && npm publish"
    },
    "keywords": [
        "discord",
        "lavalink",
        "lavalink-v4",
        "discord",
        "distube",
        "music-bot",
        "lavalink-player",
        "lavalink-client",
        "music"
    ],
    "author": "Ganyu Studios",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.3.4",
        "@types/node": "^24.10.0",
        "@types/ws": "^8.18.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.6",
        "tsup": "^8.5.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "ws": "^8.18.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
