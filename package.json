{
	"name": "hoshimi",
	"version": "0.1.0",
	"description": "A lavalink@v4 client easy to use, up-to-date.",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"packageManager": "pnpm@10.6.1+sha512.40ee09af407fa9fbb5fbfb8e1cb40fbb74c0af0c3e10e9224d7b53c7658528615b2c92450e74cfad91e3a2dcafe3ce4050d80bda71d757756d2ce2b66213e9a3",
	"files": ["dist"],
	"lint-staged": {
		"*.{ts,json}": ["pnpm format"]
	},
	"repository": {
		"url": "https://github.com/Ganyu-Studios/Hoshimi.git",
		"type": "git"
	},
	"scripts": {
		"build": "tsup",
		"lint": "biome lint .",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"prepare": "pnpm build && husky",
		"tool:prepublish": "pnpm build && tsx ./scripts/prepublish.mts && cd .npm && npm pack",
		"tool:publish": "cd .npm && npm publish"
	},
	"keywords": [
		"discord",
		"lavalink",
		"lavalink-v4",
		"discord",
		"distube",
		"music-bot",
		"lavalink-player",
		"lavalink-client",
		"music"
	],
	"author": "Ganyu Studios",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.13.10",
		"@types/ws": "^8.18.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.4.3",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2"
	},
	"dependencies": {
		"ws": "^8.18.1"
	}
}
